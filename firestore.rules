rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // 1) CLIENTES (USERS)
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      allow create: if isOwner(userId) 
                    && !("admin" in request.resource.data.roles && request.resource.data.roles.admin == true);
      
      // Strict precedence
      allow update: if (isOwner(userId) 
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles.admin'])))
                    || isAdmin();
                    
      allow delete: if isOwner(userId) || isAdmin();

      // Favoritos y Subcolecciones
      match /{document=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // 2) NEGOCIOS (BUSINESSES)
    match /businesses/{businessId} {
      allow read: if true; 

      allow create: if isOwner(businessId) || (isAuthenticated() && request.resource.data.ownerId == request.auth.uid);

      // Strict precedence
      allow update: if isOwner(businessId) || (isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin();
      
      // Strict precedence
      allow delete: if isOwner(businessId) || (isAuthenticated() && resource.data.ownerId == request.auth.uid) || isAdmin();
      
      // EXPLICIT SLOT_LOCKS (Allowed to all authed users to prevent booking transaction crash)
      match /slot_locks/{slotId} {
        allow read, write: if request.auth != null;
      }

      // Subcolecciones genéricas de negocios explicitly named to prevent wildcard bleed into slot_locks
      match /services/{docId} {
        allow read: if true;
        allow write: if isOwner(businessId) || isAdmin();
      }
      match /portfolio/{docId} {
        allow read: if true;
        allow write: if isOwner(businessId) || isAdmin();
      }
      match /bankAccounts/{docId} {
        allow read: if true;
        allow write: if isOwner(businessId) || isAdmin();
      }
      match /team/{docId} {
        allow read: if true;
        allow write: if isOwner(businessId) || isAdmin();
      }
    }

    // 3) CITAS (APPOINTMENTS)
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (
        resource.data.customerUid == request.auth.uid || 
        resource.data.businessId == request.auth.uid || 
        isAdmin()
      );
      
      allow create: if isAuthenticated() && (
        request.resource.data.customerUid == request.auth.uid || 
        request.resource.data.businessId == request.auth.uid
      );

      allow update: if isAuthenticated() && (
        resource.data.customerUid == request.auth.uid || 
        resource.data.businessId == request.auth.uid || 
        isAdmin()
      );

      allow delete: if isAdmin() || (isAuthenticated() && resource.data.businessId == request.auth.uid);
    }

    // 3.1) RESERVAS NUEVAS (BOOKINGS)
    match /bookings/{bookingId} {
      // Both the client and the business (or admin) can read the booking
      allow read: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid || 
        resource.data.businessId == request.auth.uid || 
        isAdmin()
      );
      
      // Both the client and business can create a booking
      allow create: if isAuthenticated();

      allow update: if isAuthenticated() && (
        resource.data.clientId == request.auth.uid || 
        resource.data.businessId == request.auth.uid || 
        isAdmin()
      );

      allow delete: if isAdmin() || (isAuthenticated() && resource.data.businessId == request.auth.uid);
    }

    // 3.5) CLIENTES DEL NEGOCIO (CUSTOMERS)
    match /customers/{customerId} {
      allow read, write: if isAuthenticated() && (
        resource == null ? request.resource.data.businessId == request.auth.uid : resource.data.businessId == request.auth.uid || isAdmin()
      );
    }

    // 4) NEGOCIOS PÚBLICOS_PRIVADOS
    match /businesses_public/{businessId} {
        allow read: if true;
        allow create: if isOwner(businessId);
        allow update, delete: if isOwner(businessId) || isAdmin();
        
        match /{document=**} {
            allow read: if true;
            allow write: if isOwner(businessId) || isAdmin();
        }
    }
    
    match /businesses_private/{businessId} {
        // Strict precedence
        allow read, write: if isOwner(businessId) || isAdmin();
    }
    
    // 5) RESEÑAS (REVIEWS)
    match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
        // Strict precedence
        allow update, delete: if (isAuthenticated() && resource.data.authorId == request.auth.uid) || isAdmin();
    // 6) CRM SETTINGS
    match /crm_settings/{document=**} {
        allow read: if true;
        allow write: if isAdmin();
    }
  }
}